# Dashboard backend (Hetzner container)
LOCAL_AGENT_URL=http://100.x.x.x:9830       # Tailscale IP of the Windows machine running the local agent
DASHBOARD_HOST=openclaw.yourdomain.com       # Public hostname for the dashboard
JAYCLOUD_GATEWAY_URL=                        # Optional: override the JayCloud gateway URL
JAYCLOUD_CONFIG_PATH=/root/.openclaw/openclaw.json  # Path to JayCloud's openclaw.json

# Local agent (Windows machine)
OPENCLAW_PUBLIC_HOST=100.x.x.x              # This machine's Tailscale IP (so the dashboard can build gateway URLs)
OPENCLAW_PUBLIC_SCHEME=http                  # http or https
OPENCLAW_AGENT_CONFIG=config.json            # Path to the instances config file
OPENCLAW_PYTHON=python                       # Python executable for start-agent.ps1
